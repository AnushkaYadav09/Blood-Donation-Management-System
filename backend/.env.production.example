# Production Environment Variables for Render
# Copy these to Render Dashboard → Environment Variables

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL - Use Render's Internal Database URL
DATABASE_URL=postgresql://user:password@host:5432/blood_donation

# MongoDB - Use MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/bloodconnect

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate a secure random string (at least 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secure-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=30m

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
# Gmail App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-gmail-app-password

# ============================================
# TWILIO CONFIGURATION (Optional - for SMS)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Your Vercel deployment URL
FRONTEND_URL=https://blood-donation-management-system.vercel.app

# ============================================
# SERVER CONFIGURATION
# ============================================
# Render will override this with its own port
PORT=3001
